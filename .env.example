# FloatShare 环境变量配置示例
# cp .env.example .env  然后填入真实值
# ⚠️  .env 已被 .gitignore 排除，不会入库

# Tushare Token（可选，使用 tushare 数据源时必须）
TUSHARE_TOKEN=

# Tushare Token 自动刷新（可选，token 失效时自动调用）
TUSHARE_TOKEN_REFRESH_URL=https://token.jingjingtech.com/api/v1/gtst
TUSHARE_TOKEN_REFRESH_KEY=

# 告警渠道（可选，逗号分隔，支持 80+ 种通道）
# 常用示例:
#   barks://api.day.app/<your_key>            # iOS Bark (国内首选, 22 字符 key)
#   tgram://<bot_token>/<chat_id>             # Telegram
#   mailto://user:pass@gmail.com              # 邮件
#   serverchan://<sckey>                      # Server 酱 (微信)
# 多渠道用逗号分隔: barks://api.day.app/abc,tgram://xxx/yyy
FLOATSHARE_NOTIFY_URLS=

# 日志级别
LOG_LEVEL=INFO
